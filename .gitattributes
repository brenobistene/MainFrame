# Auto-detect text files and normalize line endings to LF on commit.
# Working tree keeps platform-native (CRLF on Windows, LF elsewhere).
* text=auto eol=lf

# Windows-specific scripts must stay CRLF — cmd.exe parses them assuming it.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.db    binary
*.sqlite binary
